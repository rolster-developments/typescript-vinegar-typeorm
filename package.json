{
  "name": "@rolster/vinegar-typeorm",
  "version": "3.4.0",
  "type": "module",
  "description": "Package containing clean architecture implementations with Typeorm.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.js",
        "import": "./dist/esm/index.js"
      },
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/**/*.{ts}\"",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p tsconfig.app.json && rollup -c rollup.config.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rolster/commons": "^3.2.1",
    "@rolster/vinegar": "^3.5.0",
    "typeorm": "^0.3.27"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@rolster/rollup": "^1.0.10",
    "@rolster/types": "^1.1.0",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^3.0.2",
    "tslib": "^2.4.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-vinegar-typeorm.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "vinegar",
    "typeorm"
  ],
  "publishConfig": {
    "access": "public"
  }
}
